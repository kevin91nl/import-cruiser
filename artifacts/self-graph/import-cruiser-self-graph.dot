digraph "import_cruiser" {
    graph [rankdir=TB, splines=curved, overlap=false, ranksep=1.05, nodesep=0.6, pack=false, newrank=true, concentrate=true, compound=true, ratio="compress", fontname="Helvetica", fontsize=10, bgcolor="white", pad=0.45, margin=0.45];
    node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, color="#2F2F2F", fillcolor="#DFF3F8"];
    edge [color="#B0B0B0", arrowsize=0.7];

    subgraph "cluster_src" {
        label="src";
        class="cluster_key_src";
        margin=26;
        color="black";
        penwidth=1.0;
        style="rounded,bold";
        fontname="Helvetica";
        fontsize=9;
        "__cluster_anchor_src" [label="", shape=point, width=0, height=0, style=invis];
        subgraph "cluster_src_import_cruiser" {
            label="import_cruiser";
            class="cluster_key_src_import_cruiser";
            margin=26;
            color="black";
            penwidth=1.0;
            style="rounded,bold";
            fontname="Helvetica";
            fontsize=9;
            "import_cruiser.analyzer" [label="analyzer.py", tooltip="/Users/kevin/.codex/worktrees/ae68/pydepend/src/import_cruiser/analyzer.py", class="node_cluster_src_import_cruiser"];
            "import_cruiser.cli" [label="cli.py", tooltip="/Users/kevin/.codex/worktrees/ae68/pydepend/src/import_cruiser/cli.py", class="node_cluster_src_import_cruiser"];
            "import_cruiser.config" [label="config.py", tooltip="/Users/kevin/.codex/worktrees/ae68/pydepend/src/import_cruiser/config.py", class="node_cluster_src_import_cruiser"];
            "import_cruiser.detector" [label="detector.py", tooltip="/Users/kevin/.codex/worktrees/ae68/pydepend/src/import_cruiser/detector.py", class="node_cluster_src_import_cruiser"];
            "import_cruiser.exporter" [label="exporter.py", tooltip="/Users/kevin/.codex/worktrees/ae68/pydepend/src/import_cruiser/exporter.py", class="node_cluster_src_import_cruiser"];
            "import_cruiser.graph" [label="graph.py", tooltip="/Users/kevin/.codex/worktrees/ae68/pydepend/src/import_cruiser/graph.py", class="node_cluster_src_import_cruiser"];
            "import_cruiser.validator" [label="validator.py", tooltip="/Users/kevin/.codex/worktrees/ae68/pydepend/src/import_cruiser/validator.py", class="node_cluster_src_import_cruiser"];
        }
    }

    "import_cruiser.analyzer" -> "import_cruiser.graph";
    "import_cruiser.cli" -> "import_cruiser.analyzer";
    "import_cruiser.cli" -> "import_cruiser.config";
    "import_cruiser.cli" -> "import_cruiser.exporter";
    "import_cruiser.cli" -> "import_cruiser.graph";
    "import_cruiser.cli" -> "import_cruiser.validator";
    "import_cruiser.detector" -> "import_cruiser.graph";
    "import_cruiser.exporter" -> "import_cruiser.graph";
    "import_cruiser.validator" -> "import_cruiser.config";
    "import_cruiser.validator" -> "import_cruiser.graph";
}
